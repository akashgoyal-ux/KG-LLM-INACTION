{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FilingSummaryResult",
  "description": "Structured summary extracted from a regulatory filing (10-K / 10-Q / 8-K)",
  "type": "object",
  "required": [
    "filing_type",
    "period",
    "issuer",
    "key_facts"
  ],
  "additionalProperties": true,
  "properties": {
    "filing_type": {
      "type": "string",
      "enum": [
        "10-K",
        "10-Q",
        "8-K",
        "20-F",
        "6-K",
        "S-1",
        "DEF 14A",
        "OTHER"
      ]
    },
    "period": {
      "type": "string",
      "description": "Reporting period end date (YYYY-MM-DD or YYYY-Q#)"
    },
    "issuer": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "ticker": {
          "type": "string"
        },
        "cik": {
          "type": "string"
        },
        "lei": {
          "type": "string"
        }
      }
    },
    "key_facts": {
      "type": "array",
      "description": "Up to 10 material facts or forward-looking statements",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "fact"
        ],
        "additionalProperties": false,
        "properties": {
          "fact": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "REVENUE",
              "EARNINGS",
              "GUIDANCE",
              "RISK",
              "STRATEGY",
              "LEGAL",
              "DIVIDEND",
              "OTHER"
            ]
          },
          "numeric_value": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "page_reference": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "description": "Material risk factors mentioned",
      "items": {
        "type": "string"
      }
    },
    "forward_looking_statements": {
      "type": "array",
      "description": "Forward-looking statements flagged in the text",
      "items": {
        "type": "string"
      }
    },
    "compliance_flags": {
      "type": "array",
      "description": "Any compliance concerns detected (e.g. going concern, restatement)",
      "items": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    }
  }
}